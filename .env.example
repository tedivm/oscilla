# Oscilla development settings
# Copy this file to .env and adjust values as needed.

# Path to the game library root directory.
# The library root must contain subdirectories, each being a game package
# (a directory that contains a game.yaml file).
# Default: content/ in the project root.
# GAMES_PATH=content

# Path to the SvelteKit static build output. Mounted at /app by the web server.
# Run `make frontend_build` to generate this directory.
# Default: frontend/build
# FRONTEND_BUILD_PATH=frontend/build

# Full async-driver database URL for character persistence.
# When unset, auto-derived as:
#   sqlite+aiosqlite://<user data dir>/oscilla.db
# where <user data dir> is the platform-appropriate user data directory:
#   macOS : ~/Library/Application Support/oscilla/oscilla.db
#   Linux : ~/.local/share/oscilla/oscilla.db
# The directory is created automatically on first run.
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost/oscilla

# Enable debug mode for additional logging.
# When DEBUG=true, all log messages are written to oscilla.log in the platform
# data directory (same location as oscilla.db — see DATABASE_URL comment above).
# This is on by default for development; distributed builds have it off by default.
DEBUG=true

# Auth & SMTP
# Secret key used for JWT signing and HMAC email tokens. Must be a long,
# random string. Changing this value invalidates all existing tokens.
JWT_SECRET=change-me-in-production-this-must-be-long-and-random
# Minutes after which a web session lock is considered stale and eligible for force-takeover.
STALE_SESSION_THRESHOLD_MINUTES=10
# When true, unverified email accounts cannot access game content.
REQUIRE_EMAIL_VERIFICATION=false
# Base URL prepended to links in outbound emails (e.g. verification, password reset).
BASE_URL=http://localhost:8000
# SMTP server for transactional email (verification, password reset).
# When SMTP_HOST is unset, email sending is silently skipped.
SMTP_HOST=localhost
SMTP_PORT=1025
# Use STARTTLS; set to false for MailHog in development.
SMTP_USE_TLS=false
SMTP_FROM_ADDRESS=oscilla@localhost

# Production Security
# Rate limiting — requires Redis (CACHE_REDIS_HOST) to be effective.
# In development with the NoOpCache, rate limiting is automatically disabled.
# MAX_LOGIN_ATTEMPTS_PER_HOUR=10          # Login attempts per email per hour before 429
# MAX_REGISTRATIONS_PER_HOUR_PER_IP=5    # Registration attempts per IP per hour before 429
# MAX_LOGIN_ATTEMPTS_BEFORE_LOCKOUT=5    # Consecutive failed logins before account lockout (423)
# LOCKOUT_DURATION_MINUTES=15            # How long the lockout lasts
# LOCKOUT_WINDOW_SECONDS=300             # Rolling window for counting consecutive failures

# CORS allowed origins — JSON list of URLs.
# In production, set this to your deployed frontend URL.
# Never use ["*"] with credentials enabled.
# CORS_ORIGINS='["https://play.example.com"]'   # Production
CORS_ORIGINS='["http://localhost:5173"]'         # SvelteKit dev server (default)

# Logging level: DEBUG, INFO, WARNING, ERROR.
# LOG_LEVEL=INFO

# Number of Uvicorn worker processes (production tuning).
# UVICORN_WORKERS=1

# Minimum zxcvbn password strength score (0–4).
# Score 2 is the OWASP-aligned default. Set 0 to disable enforcement.
# MIN_PASSWORD_STRENGTH=2
